# Parent PIN required to access admin pages (changing chores, awarding points, etc.)
PARENT_PIN=1234

# Secret used to sign session cookies. MUST be changed in production!
# Use a long random string (32+ characters). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Timezone used for streak/date calculations (any IANA tz, e.g. America/New_York)
TZ=America/Los_Angeles

# When set to production, prod, or live: enforces that SESSION_SECRET
# is a real random value (not the insecure default). Prevents accidental
# insecure deploys.
ENVIRONMENT=development

# Set to true when behind a reverse proxy that terminates TLS
# (Traefik, Cloudflare Tunnel, NGINX, etc.). Enables secure/HTTPS-only
# session cookies. Only enable when SSL is actually available.
FORCE_HTTPS=false

# Kid PIN for submissions (optional). When KID_PIN_REQUIRED=true, kids
# must enter this PIN to submit chore completions or reward requests.
# This provides accountability so you know who submitted what.
KID_PIN_REQUIRED=false
KID_PIN=1234